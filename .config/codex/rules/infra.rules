# Docker read-only
prefix_rule(pattern=["docker", ["images", "logs", "ps"]], decision="allow")
prefix_rule(pattern=["docker", "compose", ["config", "logs", "ps"]], decision="allow")

# Kubernetes read-only
prefix_rule(pattern=["kubectl", ["describe", "get", "logs"]], decision="allow")
prefix_rule(pattern=[["kubectx", "kubens"]], decision="allow")
