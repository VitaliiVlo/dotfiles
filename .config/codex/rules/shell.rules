# Modern CLI tools
prefix_rule(pattern=[["bat", "dust", "exiftool", "eza", "fd", "rg", "tldr"]], decision="allow")

# Standard utilities
prefix_rule(pattern=[["awk", "basename", "cd", "cut", "date", "diff", "dirname", "echo", "false", "file", "find", "grep", "head", "ls", "printf", "ps", "pwd", "readlink", "realpath", "sed", "sleep", "sort", "stat", "tail", "tr", "tree", "true", "uname", "uniq", "wc", "which"]], decision="allow")

# Structured data
prefix_rule(pattern=[["jq", "yq"]], decision="allow")

# Clipboard
prefix_rule(pattern=[["pbcopy", "wl-copy"]], decision="allow")

# Scratch dir
prefix_rule(pattern=["mkdir", "-p", "/tmp/codex"], decision="allow")
