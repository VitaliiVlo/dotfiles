# Go
prefix_rule(pattern=["go", ["build", "doc", "fmt", "generate", "list", "test", "version", "vet"]], decision="allow")
prefix_rule(pattern=["go", "mod", ["download", "graph", "tidy", "verify", "why"]], decision="allow")
prefix_rule(pattern=[["gofmt", "golangci-lint"]], decision="allow")

# Python
prefix_rule(pattern=[["python", "python3"], "--version"], decision="allow")
prefix_rule(pattern=["uv", "--version"], decision="allow")
prefix_rule(pattern=["uv", "python", "list"], decision="allow")
prefix_rule(pattern=[["mypy", "pip-audit", "pyright", "pytest"]], decision="allow")
prefix_rule(pattern=["ruff", ["check", "format"]], decision="allow")
prefix_rule(pattern=["uv", ["build", "lock", "sync", "tree"]], decision="allow")
prefix_rule(pattern=["uv", "pip", ["list", "show"]], decision="allow")
prefix_rule(pattern=["uv", "run", ["mypy", "pip-audit", "pyright", "pytest"]], decision="allow")
prefix_rule(pattern=["uv", "run", "ruff", ["check", "format"]], decision="allow")
prefix_rule(pattern=["uvx", ["mypy", "pip-audit", "pyright", "pytest"]], decision="allow")
prefix_rule(pattern=["uvx", "ruff", ["check", "format"]], decision="allow")

# Node
prefix_rule(pattern=[["node", "npm"], "--version"], decision="allow")
prefix_rule(pattern=["fnm", ["current", "list"]], decision="allow")
prefix_rule(pattern=[["eslint", "jest", "prettier", "tsc", "vitest"]], decision="allow")
prefix_rule(pattern=["npm", ["audit", "ci", "list", "ls", "outdated", "test", "view"]], decision="allow")
prefix_rule(pattern=["npm", "run", ["build", "format", "lint", "test", "typecheck"]], decision="allow")
prefix_rule(pattern=["npx", ["eslint", "jest", "prettier", "tsc", "vitest"]], decision="allow")

# Build runner
prefix_rule(pattern=["make", ["--dry-run", "-n"]], decision="allow")

# Shell linting/formatting
prefix_rule(pattern=[["shellcheck", "shfmt"]], decision="allow")
