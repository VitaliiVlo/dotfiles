# Go
prefix_rule(pattern=["go", ["build", "doc", "generate", "list", "test", "version", "vet"]], decision="allow")
prefix_rule(pattern=["go", "mod", ["download", "tidy"]], decision="allow")
prefix_rule(pattern=["golangci-lint"], decision="allow")

# Python
prefix_rule(pattern=["mypy"], decision="allow")
prefix_rule(pattern=["pytest"], decision="allow")
prefix_rule(pattern=["ruff", "check"], decision="allow")
prefix_rule(pattern=["uv", ["lock", "sync", "tree"]], decision="allow")
prefix_rule(pattern=["uv", "pip", ["list", "show"]], decision="allow")
prefix_rule(pattern=["uv", "python", "list"], decision="allow")
prefix_rule(pattern=["uv", "--version"], decision="allow")
prefix_rule(pattern=[["python", "python3"], "--version"], decision="allow")

# Node
prefix_rule(pattern=[["eslint", "jest", "vitest"]], decision="allow")
prefix_rule(pattern=["fnm", ["current", "list"]], decision="allow")
prefix_rule(pattern=["npm", ["ci", "list", "ls", "outdated", "view"]], decision="allow")
prefix_rule(pattern=["npm", "run", ["build", "lint", "test", "typecheck"]], decision="allow")
prefix_rule(pattern=[["npm", "node"], "--version"], decision="allow")
prefix_rule(pattern=["tsc", "--noEmit"], decision="allow")

# Shell
prefix_rule(pattern=[["shellcheck", "shfmt"]], decision="allow")
