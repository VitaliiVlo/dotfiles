[user]
	email = your.email@example.com
	name = your-username

[url "git@github.com:"]
	insteadOf = https://github.com/

[core]
	autocrlf = input
	excludesfile = ~/.config/git/ignore
	editor = codium --reuse-window --wait --
	pager = delta

[init]
	defaultBranch = main

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	dark = true
	line-numbers = true
	hyperlinks = true
	side-by-side = true
	tabs = 4
	syntax-theme = Catppuccin Macchiato

[diff]
	colorMoved = default
	algorithm = histogram
	mnemonicPrefix = true
	renames = true

[merge]
	conflictstyle = zdiff3

[log]
	date = relative

[branch]
	sort = -committerdate

[fetch]
	prune = true

[pull]
	rebase = true

[rebase]
	autostash = true

[push]
	autoSetupRemote = true

[rerere]
	enabled = true
	autoupdate = true

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[alias]
	# Daily basics
	st = status
	df = diff
	dfs = diff --staged
	dfw = diff --word-diff
	dfws = diff --staged --word-diff
	# Commits
	cm = commit -m
	ca = commit --amend --no-edit
	# Log
	lg = log --oneline --graph --decorate
	# Undo
	undo = reset --soft HEAD~1
	wipe = reset --hard HEAD
