# https://ghostty.org/docs/config/reference

# General
auto-update = download
auto-update-channel = stable
desktop-notifications = true
macos-icon = official
shell-integration = zsh

# Theme (follows system appearance via window-theme = system)
theme = light:Catppuccin Latte,dark:Catppuccin Macchiato
unfocused-split-opacity = 0.5
background-opacity = 0.9
background-blur = true
bold-color = bright
selection-foreground = cell-background
selection-background = cell-foreground

# Font (fallback chain ends with Nerd Font for icons)
font-family = JetBrains Mono
font-family = Fira Code
font-family = Menlo
font-family = Monaco
font-family = Symbols Nerd Font Mono
font-size = 14
font-thicken = true
# strength 0 = lightest thickening (NOT off). Range 0-255, higher = heavier. See ghostty.org/docs/config/reference#font-thicken-strength
font-thicken-strength = 0

# Cursor
cursor-click-to-move = true
adjust-cursor-thickness = 2
cursor-style = bar
cursor-style-blink = true
cursor-opacity = 1

# Window
confirm-close-surface = true
quit-after-last-window-closed = true
window-theme = system
window-subtitle = working-directory
working-directory = home
window-inherit-working-directory = true
maximize = true
window-save-state = never
window-padding-x = 16
window-padding-y = 16
window-padding-balance = true
window-padding-color = extend

# Clipboard
clipboard-paste-protection = true
clipboard-trim-trailing-spaces = true
copy-on-select = true

# Input
macos-option-as-alt = true
mouse-hide-while-typing = true
keybind = shift+enter=text:\x1b\r
