{
  // Theme
  "workbench.colorTheme": "Catppuccin Macchiato",
  "workbench.preferredDarkColorTheme": "Catppuccin Macchiato",
  "workbench.preferredLightColorTheme": "Catppuccin Latte",
  "catppuccin.accentColor": "teal",
  "catppuccin.italicComments": true,
  "catppuccin.italicKeywords": true,
  "workbench.iconTheme": "material-icon-theme",
  "workbench.productIconTheme": "material-product-icons",
  // Workbench
  "workbench.list.smoothScrolling": true,
  "workbench.editor.highlightModifiedTabs": true,
  "workbench.startupEditor": "none",
  "workbench.tree.indent": 16,
  "workbench.editor.revealIfOpen": true,
  "workbench.editor.closeOnFileDelete": true,
  "workbench.navigationControl.enabled": false,
  // pinned (default): paired with `layoutControl.type` override below; keep explicit so the pair reads together
  "workbench.layoutControl.enabled": true,
  "workbench.layoutControl.type": "menu",
  "workbench.activityBar.location": "bottom",
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  // Window
  "window.autoDetectColorScheme": true,
  "window.commandCenter": false,
  // pinned: dependents (commandCenter, layoutControl, navigationControl, activityBar.location) require custom title bar
  "window.titleBarStyle": "custom",
  "window.zoomPerWindow": false,
  "window.zoomLevel": 0.5,
  // Font & Indentation
  "editor.fontFamily": "'JetBrains Mono', 'Fira Code', 'Menlo', 'Monaco', 'Symbols Nerd Font Mono'",
  "editor.fontSize": 14,
  "editor.lineHeight": 1.5,
  "editor.fontLigatures": true,
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.detectIndentation": true,
  "editor.autoIndent": "full",
  "editor.autoIndentOnPaste": true,
  "editor.autoIndentOnPasteWithinString": true,
  // Cursor & Scrolling
  "editor.cursorBlinking": "smooth",
  "editor.cursorStyle": "line",
  "editor.cursorWidth": 2,
  "editor.cursorSurroundingLines": 3,
  "editor.renderLineHighlight": "all",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.smoothScrolling": true,
  // Editor UX
  // pinned (default): VSCode markdown lang defaults flip wordWrap to "on"; explicit global keeps .md files unwrapped
  "editor.wordWrap": "off",
  "editor.rulers": [120],
  "editor.minimap.enabled": false,
  "editor.renderWhitespace": "selection",
  "editor.linkedEditing": true,
  "editor.stickyScroll.enabled": true,
  "editor.guides.bracketPairs": "active",
  "editor.guides.bracketPairsHorizontal": "active",
  "editor.guides.highlightActiveBracketPair": true,
  "editor.guides.highlightActiveIndentation": true,
  "editor.guides.indentation": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
  "editor.semanticHighlighting.enabled": true,
  "editor.occurrencesHighlight": "multiFile",
  "editor.autoClosingBrackets": "languageDefined",
  // Inline diagnostics (ErrorLens)
  "errorLens.messageEnabled": false,
  "errorLens.followCursor": "activeLine",
  "errorLens.followCursorMore": 3,
  "errorLens.gutterIconsEnabled": true,
  "errorLens.gutterIconsFollowCursorOverride": true,
  "errorLens.gutterIconSet": "letter",
  "errorLens.gutterIconSize": "100%",
  "errorLens.enabledDiagnosticLevels": ["error", "warning"],
  "errorLens.delay": 500,
  // IntelliSense
  "editor.quickSuggestions": {
    "other": "on",
    "comments": "on",
    "strings": "on"
  },
  "editor.suggest.preview": true,
  "editor.parameterHints.enabled": true,
  "editor.inlayHints.fontSize": 12,
  "editor.inlayHints.padding": true,
  "editor.tabCompletion": "on",
  "editor.hover.delay": 200,
  // Formatting
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "diffEditor.ignoreTrimWhitespace": false,
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit",
    "source.fixAll": "explicit",
    "source.addMissingImports": "explicit"
  },
  // Search
  "search.followSymlinks": true,
  "search.exclude": {
    "**/node_modules": true,
    "**/vendor": true,
    "**/.venv": true,
    "**/venv": true,
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/.terraform": true,
    "**/dist": true,
    "**/build": true,
    "**/.git": true,
    "**/coverage": true
  },
  // Files
  "explorer.confirmDelete": false,
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, .npmrc",
    "tsconfig.json": "tsconfig.*.json",
    "go.mod": "go.sum",
    "*.go": "${capture}_test.go",
    "Dockerfile": "Dockerfile*, .dockerignore, docker-compose.*",
    ".env": ".env.*",
    "pyproject.toml": "poetry.lock, pdm.lock, uv.lock, .python-version",
    "requirements.txt": "requirements*.txt"
  },
  "files.autoSave": "off",
  "files.insertFinalNewline": true,
  "files.eol": "\n",
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,
  // Terminal
  "terminal.integrated.fontFamily": "'JetBrains Mono', 'Fira Code', 'Menlo', 'Monaco', 'Symbols Nerd Font Mono'",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.cursorWidth": 2,
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.smoothScrolling": true,
  "terminal.integrated.fontLigatures.enabled": true,
  "terminal.integrated.macOptionIsMeta": true,
  "terminal.integrated.suggest.enabled": false,
  // Git
  "github.gitProtocol": "ssh",
  "git.confirmSync": false,
  "git.autofetch": true,
  "git.autorefresh": true,
  "git.autofetchPeriod": 300,
  "git.autoRepositoryDetection": true,
  "git.enableStatusBarSync": true,
  "git.autoStash": true,
  "git.ignoreRebaseWarning": true,
  "git.mergeEditor": true,
  "git.fetchOnPull": true,
  "git.pruneOnFetch": true,
  "git.rebaseWhenSync": true,
  "git.pullBeforeCheckout": true,
  "git.showPushSuccessNotification": true,
  "git.useCommitInputAsStashMessage": true,
  "git.openRepositoryInParentFolders": "never",
  "git.blame.editorDecoration.enabled": true,
  "git.blame.editorDecoration.template": "${authorName} (${authorDateAgo})",
  "git.blame.statusBarItem.enabled": true,
  "git.blame.statusBarItem.template": "${authorName} (${authorDateAgo})",
  "git.branchProtection": ["main", "master"],
  "scm.defaultViewMode": "tree",
  // Testing & Debug
  "testing.followRunningTest": true,
  "debug.inlineValues": "on",
  // Go tooling
  "go.diagnostic.vulncheck": "Imports",
  "go.toolsManagement.autoUpdate": true,
  "gopls": {
    "formatting.gofumpt": true,
    "ui.semanticTokens": true,
    "ui.completion.usePlaceholders": true,
    "ui.diagnostic.staticcheck": true,
    "ui.diagnostic.analyses": {
      "unusedparams": true,
      "unusedvariable": true,
      "unusedwrite": true,
      "any": true,
      "nilness": true,
      "unreachable": true,
      "shadow": true
    },
    "codelenses": {
      "generate": true,
      "tidy": true,
      "upgrade_dependency": true,
      "vendor": true,
      "test": true
    }
  },
  "go.buildTags": "integration",
  "go.buildFlags": ["-race"],
  "go.testOnSave": false,
  "go.testTags": "integration",
  "go.testFlags": ["-v", "-failfast", "-count=1", "-race", "-timeout=5m"],
  "go.lintOnSave": "package",
  "go.lintTool": "golangci-lint-v2",
  "go.lintFlags": ["--new-from-rev=origin/main", "-v", "--concurrency=0"],
  "go.inlayHints.assignVariableTypes": true,
  "go.inlayHints.compositeLiteralFields": false,
  "go.inlayHints.compositeLiteralTypes": false,
  "go.inlayHints.constantValues": true,
  "go.inlayHints.functionTypeParameters": false,
  "go.inlayHints.parameterNames": false,
  "go.inlayHints.rangeVariableTypes": true,
  "go.coverOnSingleTest": true,
  "go.coverageDecorator": {
    "type": "gutter"
  },
  // Python
  // pinned (default): forces basedpyright (detachhead.basedpyright) to own LSP; prevents ms-python from re-enabling Jedi/Pylance on extension update
  "python.languageServer": "None",
  // ms-python.vscode-python-envs auto-discovers interpreter (uv venvs, conda, system PATH); no python.defaultInterpreterPath — bare "python3" can't be resolved by the env extension's validator, absolute paths are per-machine fragile across mac/Linux.
  "python.terminal.activateEnvironment": true,
  "basedpyright.analysis.typeCheckingMode": "standard",
  "basedpyright.analysis.autoImportCompletions": true,
  "basedpyright.analysis.useLibraryCodeForTypes": true,
  "basedpyright.analysis.diagnosticMode": "openFilesOnly",
  "basedpyright.analysis.inlayHints.callArgumentNames": true,
  "basedpyright.analysis.inlayHints.variableTypes": true,
  "basedpyright.analysis.inlayHints.functionReturnTypes": true,
  "basedpyright.analysis.inlayHints.genericTypes": true,
  // Per-language formatter pins — Prettier owns its main + common supported langs; Python pinned to ruff per ruff-vscode README so format-on-save survives any future Python formatter install.
  "[javascript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[javascriptreact]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[typescript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[typescriptreact]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[json]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[jsonc]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[json5]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[yaml]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[markdown]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[mdx]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[html]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[css]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[scss]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[less]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[python]": { "editor.defaultFormatter": "charliermarsh.ruff" },
  "ruff.configurationPreference": "filesystemFirst",
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": ["--tb=short"],
  // JavaScript/TypeScript
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "js/ts.suggest.autoImports": true,
  "js/ts.suggest.completeFunctionCalls": true,
  "js/ts.inlayHints.parameterNames.enabled": "literals",
  "js/ts.inlayHints.functionLikeReturnTypes.enabled": true,
  "js/ts.inlayHints.variableTypes.enabled": true,
  "js/ts.inlayHints.propertyDeclarationTypes.enabled": true,
  "js/ts.inlayHints.enumMemberValues.enabled": true,
  "js/ts.preferences.preferTypeOnlyAutoImports": true,
  "js/ts.tsserver.maxMemory": 8192,
  // Bash / Shell (bash-language-server via mads-hartmann.bash-ide-vscode)
  "bashIde.shfmt.caseIndent": true,
  // upstream-deprecated, still passed through to shfmt; only knob exposing -kp (column alignment in macos-defaults.sh). Tracked for removal when bash-language-server drops it.
  "bashIde.shfmt.keepPadding": true,
  "bashIde.shfmt.simplifyCode": false,
  "bashIde.enableSourceErrorDiagnostics": true,
  // AI
  // pinned (default): AI feature flags flip across point releases; explicit pin survives upstream churn.
  "chat.agent.enabled": true,
  // Updates
  "update.mode": "default",
  "extensions.autoUpdate": true,
  "extensions.autoCheckUpdates": true,
  // Telemetry
  "telemetry.telemetryLevel": "off",
  "redhat.telemetry.enabled": false,
  // Workspace trust
  "security.workspace.trust.untrustedFiles": "open"
}
