// https://zed.dev/docs/configuring-zed
{
  // Theme
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Macchiato"
  },
  "icon_theme": "Material Icon Theme",
  // Font
  "buffer_font_family": "JetBrains Mono",
  "buffer_font_fallbacks": [
    "Fira Code",
    "Menlo",
    "Monaco",
    "Symbols Nerd Font Mono"
  ],
  "buffer_font_size": 14.0,
  "buffer_line_height": "comfortable",
  "ui_font_size": 16,
  // Editor UX
  "base_keymap": "VSCode",
  "cursor_shape": "bar",
  "cursor_blink": true,
  "hide_mouse": "on_typing_and_action",
  "current_line_highlight": "all",
  "show_whitespaces": "selection",
  "semantic_tokens": "combined",
  "colorize_brackets": true,
  "linked_edits": true,
  "use_autoclose": true,
  "show_completions_on_input": true,
  "show_completion_documentation": true,
  "auto_signature_help": true,
  "auto_indent_on_paste": true,
  "vertical_scroll_margin": 3.0,
  "hover_popover_delay": 200,
  "sticky_scroll": {
    "enabled": true
  },
  "minimap": {
    "show": "never"
  },
  "indent_guides": {
    "enabled": true
  },
  "wrap_guides": [120],
  "show_wrap_guides": true,
  "soft_wrap": "none",
  "inlay_hints": {
    "enabled": true
  },
  "diagnostics": {
    "inline": {
      "enabled": true,
      "max_severity": "warning",
      "update_debounce_ms": 500,
      "min_column": 80
    }
  },
  "close_on_file_delete": true,
  // Tabs & Indentation
  "tab_size": 4,
  "hard_tabs": false,
  "tabs": {
    "file_icons": true,
    "git_status": true
  },
  // Language servers
  "lsp": {
    "gopls": {
      "initialization_options": {
        "gofumpt": true,
        "semanticTokens": true,
        "usePlaceholders": true,
        "staticcheck": true,
        "analyses": {
          "unusedparams": true,
          "unusedvariable": true,
          "unusedwrite": true,
          "any": true,
          "nilness": true,
          "unreachable": true,
          "shadow": true
        },
        "hints": {
          "assignVariableTypes": true,
          "constantValues": true,
          "rangeVariableTypes": true,
          "compositeLiteralFields": false,
          "compositeLiteralTypes": false,
          "functionTypeParameters": false,
          "parameterNames": false
        },
        "codelenses": {
          "generate": true,
          "tidy": true,
          "upgrade_dependency": true,
          "vendor": true,
          "test": true
        }
      }
    },
    "bash-language-server": {
      "settings": {
        "bashIde": {
          "shfmt": {
            "simplifyCode": false
          },
          "enableSourceErrorDiagnostics": true
        }
      }
    },
    "basedpyright": {
      "settings": {
        "basedpyright.analysis": {
          "typeCheckingMode": "standard",
          "autoImportCompletions": true,
          "useLibraryCodeForTypes": true,
          "diagnosticMode": "openFilesOnly",
          "inlayHints": {
            "callArgumentNames": true,
            "variableTypes": true,
            "functionReturnTypes": true,
            "genericTypes": true
          }
        }
      }
    },
    "ruff": {
      "initialization_options": {
        "settings": {
          "configurationPreference": "filesystemFirst"
        }
      }
    },
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": { "enabled": "always" },
          "inlayHints": {
            "parameterNames": { "enabled": "literals" },
            "functionLikeReturnTypes": { "enabled": true },
            "variableTypes": { "enabled": true },
            "propertyDeclarationTypes": { "enabled": true },
            "enumMemberValues": { "enabled": true }
          },
          "suggest": {
            "completeFunctionCalls": true,
            "autoImports": true
          },
          "preferences": {
            "preferTypeOnlyAutoImports": true
          },
          "tsserver": {
            "maxTsServerMemory": 8192
          }
        },
        "javascript": {
          "updateImportsOnFileMove": { "enabled": "always" },
          "inlayHints": {
            "parameterNames": { "enabled": "literals" },
            "functionLikeReturnTypes": { "enabled": true },
            "variableTypes": { "enabled": true },
            "propertyDeclarationTypes": { "enabled": true },
            "enumMemberValues": { "enabled": true }
          },
          "suggest": {
            "completeFunctionCalls": true,
            "autoImports": true
          },
          "preferences": {
            "preferTypeOnlyAutoImports": true
          }
        }
      }
    }
  },
  // Formatting & Whitespace
  "format_on_save": "on",
  "formatter": "auto",
  "code_actions_on_format": {
    "source.organizeImports": true,
    "source.fixAll": true,
    "source.addMissingImports": true
  },
  "remove_trailing_whitespace_on_save": true,
  "ensure_final_newline_on_save": true,
  "autosave": "off",
  // Per-language formatter pins: Prettier owns its main + common supported langs (parity with VSCodium prettier-vscode). JSONC/JSON5/YAML format on save via Zed default; Markdown needs an explicit pin because Zed defaults Markdown to format_on_save "off". MDX has no Zed language (VSCodium-only).
  "languages": {
    "JavaScript": { "formatter": "prettier" },
    "JSX": { "formatter": "prettier" },
    "TypeScript": { "formatter": "prettier" },
    "TSX": { "formatter": "prettier" },
    "JSON": { "formatter": "prettier" },
    "HTML": { "formatter": "prettier" },
    "CSS": { "formatter": "prettier" },
    "SCSS": { "formatter": "prettier" },
    "Less": { "formatter": "prettier" },
    "Markdown": { "format_on_save": "on", "formatter": "prettier" }
  },
  // Search
  "use_smartcase_search": true,
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/.jj",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "**/node_modules",
    "**/.venv",
    "**/venv",
    "**/__pycache__",
    "**/.pytest_cache",
    "**/.terraform",
    "**/vendor",
    "**/dist",
    "**/build",
    "**/coverage"
  ],
  // Git
  "git": {
    "inline_blame": {
      "enabled": true,
      "show_commit_summary": false
    },
    "git_gutter": "tracked_files"
  },
  "project_panel": {
    "git_status": true
  },
  // Terminal
  "terminal": {
    "font_family": "JetBrains Mono",
    "font_fallbacks": [
      "Fira Code",
      "Menlo",
      "Monaco",
      "Symbols Nerd Font Mono"
    ],
    "font_size": 14.0,
    "cursor_shape": "bar",
    "blinking": "on",
    "option_as_meta": true
  },
  // AI
  "agent": {
    "enabled": true
  },
  // Extensions (auto-installed on launch)
  "auto_install_extensions": {
    "catppuccin": true,
    "material-icon-theme": true,
    "dockerfile": true,
    "git-firefly": true,
    "make": true,
    "proto": true,
    "rainbow-csv": true,
    "sql": true,
    "opentofu": true,
    "toml": true,
    "tombi": true
  },
  // Updates
  "auto_update": true,
  // Telemetry
  "telemetry": {
    "diagnostics": true,
    "metrics": false
  }
}
