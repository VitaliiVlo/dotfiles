# Per-machine overrides (see `.local.example.toml` and README "Local overrides")
.local/

# Duplicates of ~/.config/git/ignore so this repo is protected on fresh clones
# (before `make symlinks` wires the global ignore) and for outside contributors
# who do not share this dotfiles setup.
.DS_Store
.env
.env.*
.idea/
.vscode/
__pycache__/
*.pyc
*.swp

# AI tools: ignore only per-project local files, never the whole .claude/ tree (keeps future tracked .claude/ content shareable)
.claude/settings.local.json
CLAUDE.local.md
AGENTS.local.md
